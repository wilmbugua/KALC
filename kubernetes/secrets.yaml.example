# Example Kubernetes Secret for KALC POS Database Credentials
# Copy this file to secrets.yaml and customize with your actual credentials
# NEVER commit secrets.yaml to version control - it contains sensitive information
# Add secrets.yaml to your .gitignore or use external secret management

apiVersion: v1
kind: Secret
metadata:
  name: kalcpos-db-credentials
  namespace: kalcpos
type: Opaque
stringData:
  username: your_database_username
  password: your_database_password
  server: mysql-service
  database: KALCpos

# Alternative: Create secret from files (more secure)
# echo -n "your_database_username" > ./username.txt
# echo -n "your_database_password" > ./password.txt
# kubectl create secret generic kalcpos-db-credentials \\
#   --from-file=username=./username.txt \\
#   --from-file=password=./password.txt \\
#   --from-literal=server=mysql-service \\
#   --from-literal=database=KALCpos \\
#   --namespace=kalcpos